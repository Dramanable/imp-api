{
  "apps": [
    {
      "name": "impalia-api",
      "script": "dist/main.js",

      "instances": 2,
      "exec_mode": "cluster",

      "max_memory_restart": "512M",
      "restart_delay": 3000,
      "max_restarts": 10,

      "env_production": {
        "NODE_ENV": "production",
        "PORT": 3000,
        "CORS_ORIGIN": "https://test-imp.a3s-securite.com,https://www.test-imp.a3s-securite.com",
        "OPENAI_MODEL": "gpt-3.5-turbo",
        "LLM_TEMPERATURE": "0.7",
        "LLM_MAX_TOKENS": "1024",
        "REDIS_HOST": "127.0.0.1",
        "REDIS_PORT": "6379",
        "LOG_LEVEL": "info",
        "CACHE_TTL_MS": "3600000"
      },

      "error_file": "/home/amadou/impalia/logs/error.log",
      "out_file": "/home/amadou/impalia/logs/out.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "merge_logs": true
    }
  ]
}
