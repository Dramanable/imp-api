# ── LLM (OpenAI) ─────────────────────────────────────────────────────────────
# Required. Your OpenAI API key. Never commit the real value.
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI model to use. Defaults to gpt-4o-mini.
OPENAI_MODEL=gpt-4o-mini

# LLM sampling temperature (0.0 = deterministic, 1.0 = creative). Default: 0.7
LLM_TEMPERATURE=0.7

# Maximum tokens the LLM may generate per request. Default: 1024
LLM_MAX_TOKENS=1024

# ── Server ────────────────────────────────────────────────────────────────────
# HTTP port. Default: 3000
PORT=3000

# Runtime environment. Set to "production" to enable CSP and stricter settings.
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Use "*" only in development. Always restrict this in production.
CORS_ORIGIN=http://localhost:5173,http://localhost:3001

# ── Logging ───────────────────────────────────────────────────────────────────
# Pino log level: trace | debug | info | warn | error | fatal. Default: info
LOG_LEVEL=info

# ── Cache ─────────────────────────────────────────────────────────────────────
# In-memory cache TTL in milliseconds. Default: 3600000 (1 hour)
CACHE_TTL_MS=3600000

